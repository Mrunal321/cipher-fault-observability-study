+
+    run_mmig_stage( ntk, "mmig-area:rewrite-pre", ps, st.cec, [&]( auto& candidate ) {
+      mmig_algebraic_rewriting_params rw_ps;
+      rw_ps.max_iterations = ps.max_iterations;
