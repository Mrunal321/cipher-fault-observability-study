index 0000000..9f2f8cd
--- /dev/null
+++ b/include/mockturtle/algorithms/mmig_minority_seeding.hpp
@@ -0,0 +1,613 @@
+/* mockturtle: C++ logic network library
+ * Copyright (C) 2018-2022  EPFL
