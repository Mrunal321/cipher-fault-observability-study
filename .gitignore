# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
.venv/
venv/

# Vivado byproducts (must not be re-committed if user re-runs the FPGA flow)
*.jou
*.log
vivado*.backup.jou
vivado*.backup.log
.Xil/
fsm_encoding.os
*.dcp
*.rpt
*.pb
*.str

# LaTeX build artifacts
paper/tex/*.aux
paper/tex/*.bbl
paper/tex/*.blg
paper/tex/*.fdb_latexmk
paper/tex/*.fls
paper/tex/*.log
paper/tex/*.out
paper/tex/*.pdf
paper/tex/*.synctex.gz

# Submission PDFs (contain venue name — keep out of public repo)
paper/*.pdf

# Backup files created during editing
*.corrupt.bak

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp
*.swo
